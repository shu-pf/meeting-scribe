# コピーして .env として保存し、値を埋めてください。
# cp .env.example .env

NOTARY_APPLE_ID=your@email.com
NOTARY_TEAM_ID=XXXXXXXXXX
NOTARY_PASSWORD=xxxx-xxxx-xxxx-xxxx
NOTARY_IDENTITY="Developer ID Application: Your Name (XXXXXXXXXX)"

# 任意: 署名・公証後の成果物の出力先（省略時はリポジトリの dist/）
# DIST_DIR=/absolute/path/to/output

# 任意: Sparkle ツールのディレクトリ（省略時は DerivedData から自動検出）
# SPARKLE_BIN_DIR=/path/to/Sparkle/bin

# 任意: appcast 内のダウンロード URL プレフィックス
# DOWNLOAD_URL_PREFIX=https://github.com/shu-pf/meeting-scribe/releases/download/v1.0.0/
